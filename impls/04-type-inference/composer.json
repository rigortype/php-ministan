{
    "name": "ministan/ministan",
    "description": "ministan — the live implementation (reader snapshots are generated from git history into impls/)",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.3",
        "nikic/php-parser": "^5.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Ministan\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ministan\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/ministan"
    ],
    "config": {
        "sort-packages": true
    }
}
