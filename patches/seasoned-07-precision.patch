+        $discovered = $this->silently(fn (): Scope => $this->processStmts($stmts, $entry));
+        $widened = $entry->mergeWith($discovered);
+
+        $result = $this->processStmts($stmts, $widened);
+
+        return $widened->mergeWith($result);
+    }
