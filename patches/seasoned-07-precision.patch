+     * @param callable(): Scope $fn
+     */
+    private function silently(callable $fn): Scope
+    {
+        $saved = $this->nodeCallback;
+        $this->nodeCallback = static function (): void {
+        };
+
+        try {
+            return $fn();
+        } finally {
+            $this->nodeCallback = $saved;
+        }
+    }
